<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Автомобиль -->
        <ImageView
            android:id="@+id/imgCar"
            android:layout_width="280dp"
            android:layout_height="140dp"
            android:src="@drawable/ic_splash_car"
            android:contentDescription="Car"/>

        <!-- Название -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Car Fuel Monitor"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-light"/>

        <!-- Подзаголовок -->
        <TextView
            android:id="@+id/txtSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Мониторинг топлива"
            android:textSize="16sp"
            android:textColor="#B0B0B0"/>

        <!-- Прогресс бар -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="200dp"
            android:layout_height="4dp"
            android:layout_marginTop="32dp"
            android:indeterminate="true"
            android:indeterminateTint="#2196F3"/>

        <!-- Версия -->
        <TextView
            android:id="@+id/txtVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Version 1.1.0"
            android:textSize="12sp"
            android:textColor="#666666"/>

    </LinearLayout>

    <!-- Копирайт -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp"
        android:text="GradusXaker © 2024"
        android:textSize="10sp"
        android:textColor="#444444"/>

</RelativeLayout>
